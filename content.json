{"meta":{"title":"古琴记录","subtitle":"鳶飛魚躍，無處不是化境。","description":"","author":"宋雨轩","url":"https://yizhen20.github.io"},"pages":[{"title":"about","date":"2020-04-04T04:45:37.000Z","updated":"2020-04-30T04:02:16.648Z","comments":true,"path":"about/index-1.html","permalink":"https://yizhen20.github.io/about/index-1.html","excerpt":"","text":""},{"title":"categories","date":"2020-04-30T03:57:56.000Z","updated":"2020-04-30T04:00:21.533Z","comments":true,"path":"categories/index-2.html","permalink":"https://yizhen20.github.io/categories/index-2.html","excerpt":"","text":""},{"title":"categories","date":"2020-04-04T04:45:44.000Z","updated":"2020-04-30T04:00:11.931Z","comments":true,"path":"categories/index-1.html","permalink":"https://yizhen20.github.io/categories/index-1.html","excerpt":"","text":""},{"title":"about","date":"2020-04-04T03:50:53.000Z","updated":"2020-04-04T03:51:47.313Z","comments":true,"path":"about/index.html","permalink":"https://yizhen20.github.io/about/index.html","excerpt":"","text":""},{"title":"categories","date":"2020-04-04T02:32:35.000Z","updated":"2020-04-04T02:33:04.645Z","comments":true,"path":"categories/index.html","permalink":"https://yizhen20.github.io/categories/index.html","excerpt":"","text":""},{"title":"categories1","date":"2020-04-30T04:10:56.000Z","updated":"2020-04-30T04:19:19.667Z","comments":false,"path":"categories1/index.html","permalink":"https://yizhen20.github.io/categories1/index.html","excerpt":"","text":""},{"title":"categories3","date":"2020-04-30T04:11:08.000Z","updated":"2020-04-30T04:19:35.697Z","comments":false,"path":"categories3/index.html","permalink":"https://yizhen20.github.io/categories3/index.html","excerpt":"","text":""},{"title":"categories2","date":"2020-04-30T04:11:02.000Z","updated":"2020-04-30T04:19:27.720Z","comments":false,"path":"categories2/index.html","permalink":"https://yizhen20.github.io/categories2/index.html","excerpt":"","text":""},{"title":"tags","date":"2020-04-30T03:58:05.000Z","updated":"20